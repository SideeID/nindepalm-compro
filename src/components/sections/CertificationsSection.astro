---
import { CERTIFICATIONS } from '@/lib/constants';
import { ShieldCheck, Star, Award } from 'lucide-react';

const icons = {
  ShieldCheck,
  Star,
  Award
};
---

<!-- FIX #5: Smaller certification badges, compact layout -->
<section class="bg-amber-50 py-14 border-b border-amber-200/50">
  <div class="max-w-7xl mx-auto px-6">
    <p class="text-center text-xs font-bold text-amber-600 uppercase tracking-widest mb-8">Certified & Compliant</p>
    <div class="flex flex-wrap justify-center items-center gap-10 md:gap-20 grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-700">
      {CERTIFICATIONS.map(cert => {
        const Icon = icons[cert.icon as keyof typeof icons] || ShieldCheck;
        return (
          <div class="flex flex-col items-center gap-2.5 group cursor-pointer">
            <!-- Smaller circle: w-14 h-14 instead of w-20 h-20 -->
            <div class="w-14 h-14 rounded-full bg-white flex items-center justify-center border border-amber-200 shadow-sm group-hover:border-amber-500 group-hover:shadow-amber-200 transition-all duration-500">
              <Icon className="w-7 h-7 text-amber-600 group-hover:scale-110 transition-transform duration-400" />
            </div>
            <div class="text-center">
              <span class="font-bold text-amber-900 block text-sm">{cert.abbr}</span>
              <span class="text-[10px] text-amber-700/60">{cert.number}</span>
            </div>
          </div>
        )
      })}
    </div>
  </div>
</section>
