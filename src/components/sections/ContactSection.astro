---
import { WHATSAPP_LINK } from '@/lib/constants';
import { MessageSquare, Mail, Phone } from 'lucide-react';
---

<section id="contact" class="py-24 bg-amber-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="bg-amber-800 rounded-3xl overflow-hidden shadow-2xl relative">
      <div class="absolute top-0 right-0 w-1/3 h-full bg-white/5 -skew-x-12 translate-x-1/2"></div>

      <div class="p-10 relative z-10 flex flex-col md:flex-row items-center gap-12">
        <div class="md:w-2/3">
          <h2 class="text-2xl md:text-2xl font-bold text-white mb-4 leading-tight" style="font-family: 'Playfair Display', serif;">
            Ready to Experience <br/>Indonesian Gold?
          </h2>
          <p class="text-amber-100/80 text-sm md:text-base mb-8 max-w-xl leading-relaxed">
            Consult with our export specialists about bulk orders, customization, or private labeling for your brand.
          </p>

          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-5 mb-6">
            <a href={WHATSAPP_LINK} target="_blank" class="bg-[#25D366] hover:bg-[#128C7E] text-white px-5 py-2.5 rounded-lg text-sm font-semibold flex items-center gap-2 transition-transform active:scale-95 shadow-md">
              <MessageSquare className="w-4 h-4 fill-current" />
              Chat di WhatsApp
            </a>

            <div class="flex flex-col gap-2">
              <div class="flex items-center gap-2 text-white">
                <Mail className="text-amber-300 w-4 h-4 shrink-0" />
                <span class="text-xs font-medium">hello@nindepalm.com</span>
              </div>
              <div class="flex items-center gap-2 text-white">
                <Phone className="text-amber-300 w-4 h-4 shrink-0" />
                <span class="text-xs font-medium">+62 877 5869 9681</span>
              </div>
            </div>
          </div>
        </div>

        <div class="md:w-1/3 w-full">
          <div class="bg-white p-4 rounded-2xl shadow-xl rotate-3 hover:rotate-0 transition-transform duration-500">
            <div class="w-full aspect-square rounded-xl overflow-hidden">
              <img
                alt="Peta Lokasi NINDEPALM — Lumajang, Jawa Timur"
                src="/images/contact-map.png"
                class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Form -->
    <!-- <div class="mt-10 max-w-lg mx-auto bg-white p-6 rounded-xl shadow-sm border border-amber-100">
      <h3 class="font-bold text-amber-900 text-base border-b border-amber-100 pb-2 mb-4">Kirim Pesan Email</h3>
      <form action="mailto:hello@nindepalm.com" method="GET" class="flex flex-col gap-3">
        <input type="text" name="subject" placeholder="Nama / Perusahaan" required class="w-full px-3 py-2 rounded-md border border-amber-200 focus:outline-none focus:ring-2 focus:ring-amber-500 bg-amber-50 text-xs" />
        <textarea name="body" placeholder="Pesan Anda..." required rows="4" class="w-full px-3 py-2 rounded-md border border-amber-200 focus:outline-none focus:ring-2 focus:ring-amber-500 bg-amber-50 text-xs resize-none"></textarea>
        <button type="submit" class="w-full bg-amber-600 hover:bg-amber-700 text-white font-semibold py-2 rounded-md transition-colors text-xs">
          Kirim Email
        </button>
      </form>
    </div> -->
  </div>
</section>
