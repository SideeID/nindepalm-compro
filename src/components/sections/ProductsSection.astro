---
import { PRODUCTS } from '@/lib/constants';
import SectionHeading from '../ui/SectionHeading.astro';

const productImages: Record<number, string> = {
  1: '/images/product-granules.png',
  2: '/images/product-wheel.png',
  3: '/images/product-dakon.png',
};
---

<section id="products" class="py-20 bg-amber-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
      <SectionHeading title="Our Products" subtitle="Selection" class="mb-0" />
      <p class="text-amber-800/80 max-w-md pb-4 text-sm">100% natural sweetener with a low glycemic index, rich in minerals and authentic aroma.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {PRODUCTS.map(product => (
        <div class="group bg-white rounded-2xl overflow-hidden border border-amber-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col">
          <!-- Image -->
          <div class="aspect-square bg-amber-100 overflow-hidden relative">
            <img
              alt={product.name}
              src={productImages[product.id]}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              loading="lazy"
            />
            <div class="absolute top-3 right-3">
              <span class="bg-amber-600 text-white text-[9px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full shadow">
                {product.badge}
              </span>
            </div>
          </div>

          <!-- Content -->
          <div class="p-5 flex flex-col flex-grow">
            <div class="mb-3">
              <h3 class="text-lg font-bold text-amber-900 leading-snug mb-0.5" style="font-family: 'Playfair Display', serif;">{product.name}</h3>
              <p class="text-xs font-medium text-amber-500 italic">"{product.localName}"</p>
            </div>

            <div class="space-y-1.5 mb-4 bg-amber-50 p-3 rounded-xl border border-amber-100 text-xs">
              <div class="flex justify-between">
                <span class="text-amber-700/60 font-medium">Form</span>
                <span class="text-amber-900 font-semibold">{product.form}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-amber-700/60 font-medium">Packaging</span>
                <span class="text-amber-900 font-semibold">{product.packaging}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-amber-700/60 font-medium">Price</span>
                <span class="text-amber-700 font-bold">{product.price}</span>
              </div>
            </div>

            <p class="text-amber-800/80 text-xs mb-5 leading-relaxed flex-grow">
              {product.description}
            </p>

            <!-- FIX #3: smaller request info button -->
            <a href="#contact" class="block w-full py-2.5 border border-amber-200 text-center text-amber-800 font-semibold rounded-lg hover:bg-amber-600 hover:border-amber-600 hover:text-white transition-all duration-300 text-sm">
              Request Info
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
