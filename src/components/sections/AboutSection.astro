---
import TimelineAnimated from '../interactive/TimelineAnimated.tsx';
---

<section id="about" class="py-24 bg-amber-100">
  <div class="max-w-container mx-auto px-6">
    <div class="text-center mb-20">
      <span class="text-amber-600 font-bold tracking-widest uppercase text-xs mb-3 block">Heritage</span>
      <h2 class="text-4xl md:text-5xl font-bold font-heading text-amber-900">Our Story</h2>
    </div>
    
    <div class="relative">
      <!-- Timeline Line -->
      <div class="absolute left-1/2 -translate-x-1/2 h-full w-px bg-amber-200 hidden md:block"></div>
      
      <!-- React Island -->
      <TimelineAnimated client:visible />
    </div>

    <!-- Founder Quote -->
    <div class="mt-32 max-w-3xl mx-auto text-center relative">
      <div class="absolute -top-10 left-1/2 -translate-x-1/2 text-8xl text-amber-300/30 font-heading leading-none">"</div>
      <blockquote class="text-xl md:text-2xl italic font-heading text-amber-800 leading-relaxed mb-8 relative z-10">
        "We do not merely sell coconut sugar. We nurture the natural heritage of Java and pass it on to the world."
      </blockquote>
      <div class="flex items-center justify-center gap-4">
        <div class="h-px w-12 bg-amber-300"></div>
        <cite class="not-italic font-bold text-amber-900 uppercase tracking-widest text-sm">Saiful Afifan</cite>
        <div class="h-px w-12 bg-amber-300"></div>
      </div>
      <p class="text-amber-700/80 text-sm mt-2 font-medium">Founder of NINDEPALM</p>
    </div>
  </div>
</section>
