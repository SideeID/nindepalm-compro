---
---

<section class="py-24 bg-amber-100">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="text-amber-600 font-bold tracking-widest uppercase text-[10px] mb-2 block">Family</span>
        <h2 class="text-3xl font-bold text-amber-900 mb-6" style="font-family: 'Playfair Display', serif;">
          17 Dedicated <br/>Employees
        </h2>
        <p class="text-sm md:text-base text-amber-800/80 leading-relaxed mb-8">
          Our team consists of expert food technologists, traditional master palm sugar cookers, and logistics specialists who ensure every batch meets our "Premium with Integrity" promise.
        </p>

        <div class="flex items-center gap-6">
          <div class="flex -space-x-4">
            <div class="w-12 h-12 rounded-full border-2 border-amber-100 bg-white overflow-hidden shadow-sm">
              <img alt="Team member" src="/images/team-member-1.png" class="w-full h-full object-cover" loading="lazy"/>
            </div>
            <div class="w-12 h-12 rounded-full border-2 border-amber-100 bg-white overflow-hidden shadow-sm">
              <img alt="Team member" src="/images/team-member-2.png" class="w-full h-full object-cover" loading="lazy"/>
            </div>
            <div class="w-12 h-12 rounded-full border-2 border-amber-100 bg-white overflow-hidden shadow-sm">
              <img alt="Team member" src="/images/team-member-3.png" class="w-full h-full object-cover" loading="lazy"/>
            </div>
          </div>
          <p class="text-sm font-bold text-amber-700">Joining forces for global impact</p>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <img class="rounded-xl aspect-[3/4] object-cover mt-12 shadow-lg" alt="Team working" src="/images/team-work.png" loading="lazy"/>
        <img class="rounded-xl aspect-[3/4] object-cover shadow-lg" alt="Farmers harvesting" src="/images/team-harvest.png" loading="lazy"/>
      </div>
    </div>
  </div>
</section>
