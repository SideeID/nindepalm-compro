---
import { YOUTUBE_VIDEOS } from '@/lib/constants';
import { Play } from 'lucide-react';

const mediaTitles = [
  'Harvesting the Sap',
  'The Crystallization Process',
  'Quality Assurance Standards',
  'Ready for Global Shipment',
];

const localThumbs = [
  '/images/media-video-1.png',
  '/images/media-video-2.png',
  '/images/media-video-3.png',
  '/images/media-video-4.png',
];
---

<section class="py-24 bg-amber-950">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div>
        <span class="text-amber-400 font-bold tracking-widest uppercase text-xs mb-3 block">Media & Gallery</span>
        <h2 class="text-3xl font-bold text-white" style="font-family: 'Playfair Display', serif;">Processing Insights</h2>
      </div>
      <a href="https://youtube.com" target="_blank" class="text-amber-400 hover:text-white transition-colors flex items-center gap-2 group text-sm font-bold uppercase tracking-wider">
        Watch all videos
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {YOUTUBE_VIDEOS.map((video, index) => (
        <a
          href={video.url}
          target="_blank"
          class="group relative aspect-video bg-amber-900 rounded-xl overflow-hidden cursor-pointer shadow-lg block"
          aria-label={mediaTitles[index]}
        >
          <img
            alt={mediaTitles[index]}
            src={localThumbs[index]}
            class="w-full h-full object-cover opacity-60 group-hover:opacity-90 group-hover:scale-105 transition-all duration-500"
            loading="lazy"
          />
          <!-- Play button -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-14 h-14 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center group-hover:scale-110 group-hover:bg-white/30 transition-all duration-300">
              <Play className="w-6 h-6 text-white ml-1" />
            </div>
          </div>
          <!-- Label -->
          <div class="absolute bottom-0 left-0 w-full p-4 bg-gradient-to-t from-black/80 to-transparent">
            <p class="text-white text-sm font-medium">{mediaTitles[index]}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
