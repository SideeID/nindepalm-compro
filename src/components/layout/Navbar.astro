---
import NavbarMobile from '../interactive/NavbarMobile.tsx';
import { Button } from '../ui/button';
import { COMPANY_NAME, WHATSAPP_LINK } from '@/lib/constants';

const navLinks = [
  { href: '#home', label: 'Home' },
  { href: '#about', label: 'About' },
  { href: '#products', label: 'Products' },
  { href: '#vision', label: 'Vision' },
  { href: '#contact', label: 'Contact' },
];
---

<nav id="navbar" class="fixed top-0 w-full z-50 transition-all duration-300 bg-transparent border-b border-transparent">
  <div class="max-w-container mx-auto px-6 py-3 flex justify-between items-center">
    <!-- Brand -->
    <a href="/" class="font-heading font-bold text-xl text-amber-700 tracking-tight">
      {COMPANY_NAME}
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex gap-8 items-center">
      {navLinks.map(link => (
        <a
          href={link.href}
          data-navlink={link.href.replace('#', '')}
          class="nav-link text-amber-800/80 hover:text-amber-900 transition-colors text-sm font-medium pb-0.5 border-b-2 border-transparent"
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-4">
      <a href={WHATSAPP_LINK} target="_blank" class="hidden md:block">
        <Button className="bg-amber-500 hover:bg-amber-600 text-white rounded-md px-5 py-2 h-auto text-sm font-semibold shadow-sm transition-transform active:scale-95">
          Hubungi Kami
        </Button>
      </a>
      <NavbarMobile client:load />
    </div>
  </div>
</nav>

<script>
  // ─── Scroll-to-blur effect ───────────────────────────────────────────────
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.add('bg-amber-50/95', 'backdrop-blur-md', 'shadow-sm', 'border-amber-200/50');
      navbar?.classList.remove('bg-transparent', 'border-transparent');
    } else {
      navbar?.classList.remove('bg-amber-50/95', 'backdrop-blur-md', 'shadow-sm', 'border-amber-200/50');
      navbar?.classList.add('bg-transparent', 'border-transparent');
    }
  });

  // ─── Active link on scroll (IntersectionObserver) ────────────────────────
  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('a[data-navlink]');

  const ACTIVE_CLASSES  = ['text-amber-900', 'font-bold', 'border-amber-600'];
  const DEFAULT_CLASSES = ['text-amber-800/80', 'font-medium', 'border-transparent'];

  function setActive(id: string) {
    navLinks.forEach(link => {
      const isActive = link.dataset.navlink === id;
      ACTIVE_CLASSES.forEach(cls => link.classList.toggle(cls, isActive));
      DEFAULT_CLASSES.forEach(cls => link.classList.toggle(cls, !isActive));
    });
  }

  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
        }
      });
    },
    { rootMargin: '-40% 0px -55% 0px', threshold: 0 }
  );

  sections.forEach(section => observer.observe(section));

  // Set initial active based on hash or default to 'home'
  const initial = window.location.hash.replace('#', '') || 'home';
  setActive(initial);
</script>
